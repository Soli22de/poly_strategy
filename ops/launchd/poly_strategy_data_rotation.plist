<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>poly_strategy_data_rotation</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/ww/Project/poly_strategy &amp;&amp; DATA_DIR=data MAX_BYTES=104857600 RETENTION_DAYS=7 INCLUDE_REPORTS=0 scripts/rotate_data.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>1800</integer>
  <key>WorkingDirectory</key>
  <string>/Users/ww/Project/poly_strategy</string>
  <key>StandardOutPath</key>
  <string>/Users/ww/Project/poly_strategy/data/data-rotation.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/ww/Project/poly_strategy/data/data-rotation.log</string>
</dict>
</plist>
